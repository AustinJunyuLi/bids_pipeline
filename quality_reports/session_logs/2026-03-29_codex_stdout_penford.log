    nda_signer_ids: set[str] = set()
    downstream_actor_ids: set[str] = set()

    for event in events:
        if event.event_type == "nda":
            nda_signer_ids.update(event.actor_ids)
        if event.event_type in {"proposal", "drop", "executed", "terminated"}:
