{"block_id": "B003", "document_id": "0001193125-14-455030", "ordinal": 3, "start_line": 1275, "end_line": 1276, "raw_text": "As a consequence of such reviews during the past six years, Penford determined, among other things, to dispose of its two Australian\nfacilities, its New Zealand facility and its dextrose products business.", "clean_text": "As a consequence of such reviews during the past six years, Penford determined, among other things, to dispose of its two Australian facilities, its New Zealand facility and its dextrose products business.", "is_heading": false, "page_break_before": false, "page_break_after": false, "date_mentions": [], "entity_mentions": [], "evidence_density": 0, "temporal_phase": "initiation"}
