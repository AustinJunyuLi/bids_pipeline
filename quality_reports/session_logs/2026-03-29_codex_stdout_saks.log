def _gate_actor_lifecycle(artifacts: LoadedExtractArtifacts) -> list[GateFinding]:
    actors, events = _get_actor_event_records(artifacts)
    bidder_ids = {actor.actor_id for actor in actors if actor.role == "bidder"}
    nda_by_bidder: Counter[str] = Counter()
    proposal_by_bidder: Counter[str] = Counter()
    drop_by_bidder: Counter[str] = Counter()
    executed_bidders: set[str] = set()

    for event in events:
        actor_ids = set(event.actor_ids)
        if event.event_type == "nda":
            nda_by_bidder.update(bidder_ids.intersection(actor_ids))
        elif event.event_type == "proposal":
            proposal_by_bidder.update(bidder_ids.intersection(actor_ids))
        elif event.event_type == "drop":
            drop_by_bidder.update(bidder_ids.intersection(actor_ids))
        elif event.event_type == "executed":
            executed_bidders.update(bidder_ids.intersection(actor_ids))
            if event.executed_with_actor_id in bidder_ids:
                executed_bidders.add(event.executed_with_actor_id)

    findings: list[GateFinding] = []

    for bidder_id in sorted(bidder_ids):
        nda_count = nda_by_bidder[bidder_id]
        proposal_count = proposal_by_bidder[bidder_id]
        drop_count = drop_by_bidder[bidder_id]
        if nda_count == 0 and proposal_count == 0 and drop_count == 0 and bidder_id not in executed_bidders:
            findings.append(
                GateFinding(
                    gate_id="actor_lifecycle",
                    rule_id="bidder_never_used",
                    severity="warning",
                    description=f"Bidder {bidder_id} has no NDA, proposal, drop, or executed event.",
                    actor_ids=[bidder_id],
                )
            )
            continue

        if drop_count > 0 and nda_count == 0 and bidder_id not in executed_bidders:
            findings.append(
                GateFinding(
                    gate_id="actor_lifecycle",
                    rule_id="drop_without_prior_nda",
                    severity="blocker",
                    description=f"Bidder {bidder_id} drops without prior NDA in the same extracted timeline.",
                    actor_ids=[bidder_id],
                )
            )

    return findings


def _gate_attention_decay(
    sorted_events: list,
    blocks: list[ChronologyBlock],
) -> GateAttentionDecay | None:
    if len(sorted_events) < WINDOW_SIZE:
        return None

    block_positions: dict[str, int] = {block.block_id: idx for idx, block in enumerate(blocks)}
    windows: list[dict] = []
    max_density = 0

    for start in range(0, len(sorted_events) - WINDOW_SIZE + 1):
        window_events = sorted_events[start : start + WINDOW_SIZE]
        evidence_positions: list[int] = []
        for event in window_events:
            block_ids = getattr(event, "_gate_block_ids", [])
            evidence_positions.extend(
                pos for block_id in block_ids if (pos := block_positions.get(block_id)) is not None
            )
        if not evidence_positions:
            continue
        span = max(evidence_positions) - min(evidence_positions)
        density = len(window_events) / max(span, 1)
        max_density = max(max_density, density)
        windows.append(
            {
                "event_ids": [event.event_id for event in window_events],
                "block_span": span,
                "density": round(density, 3),
            }
        )

    hot_spots = [
        window["event_ids"]
        for window in windows
        if window["density"] >= HOT_SPOT_THRESHOLD
    ]
    if not hot_spots and max_density < HOT_SPOT_THRESHOLD:
        return None

    return GateAttentionDecay(
        max_density=round(max_density, 3),
        hot_spots=hot_spots,
        windows=windows,
    )


def _prepare_sorted_events(artifacts: LoadedExtractArtifacts) -> tuple[list, list[str]]:
    _, events = _get_actor_event_records(artifacts)
    return _sort_events_by_date(events)


def _attach_gate_block_ids(artifacts: LoadedExtractArtifacts, events: list) -> None:
    for event in events:
        setattr(event, "_gate_block_ids", _event_block_ids(artifacts, event))


def _build_summary(findings: list[GateFinding]) -> GateReportSummary:
    blocker_count = sum(1 for finding in findings if finding.severity == "blocker")
    warning_count = sum(1 for finding in findings if finding.severity == "warning")
    status: Literal["pass", "fail"] = "fail" if blocker_count > 0 else "pass"
    return GateReportSummary(
        status=status,
        finding_count=len(findings),
        blocker_count=blocker_count,
        warning_count=warning_count,
    )


def run_gates(deal_slug: str, *, project_root: Path = PROJECT_ROOT) -> int:
    paths = build_skill_paths(deal_slug, project_root=project_root)
    artifacts = load_extract_artifacts(paths)
    blocks = _load_chronology_blocks(paths)
    sorted_events, undated_event_ids = _prepare_sorted_events(artifacts)
    _attach_gate_block_ids(artifacts, sorted_events)
    cycle_ranges = _cycle_ranges(sorted_events)

    findings: list[GateFinding] = []
    findings.extend(_gate_temporal_consistency(artifacts, blocks))
    findings.extend(_gate_cross_event_logic(sorted_events, cycle_ranges, undated_event_ids))
    findings.extend(_gate_actor_lifecycle(artifacts))

    attention = _gate_attention_decay(sorted_events, blocks)

    report = GateReport(
        findings=findings,
        summary=_build_summary(findings),
        attention_decay=attention,
    )
    ensure_output_directories(paths)
    _write_json(paths.gates_report_path, report)
    return 1 if report.summary.status == "fail" else 0

