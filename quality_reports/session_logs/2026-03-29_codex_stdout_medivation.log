    for actor in actors:
        if actor.role == "bidder" and actor.bidder_kind is None:
            findings.append(
                CheckFinding(
                    check_id="bidder_kind_missing",
                    severity="warning",
                    description="Bidder actors should have bidder_kind.",
                    actor_ids=[actor.actor_id],
                )
            )
    return findings


