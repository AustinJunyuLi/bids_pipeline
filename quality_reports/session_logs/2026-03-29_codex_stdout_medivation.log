                "quote_id": quote_id,
                "block_id": actor.get("quote_block_id", default_block_id),
                "text": actor["display_name"],
            }
        )
        actor_records.append(
            {
                "actor_id": actor["actor_id"],
                "display_name": actor["display_name"],
                "canonical_name": actor["canonical_name"],
                "aliases": [],
                "role": "bidder",
