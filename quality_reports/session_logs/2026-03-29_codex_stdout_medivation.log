) -> BidClassification:
    """Apply deterministic bid classification. Residual -> Uncertain."""
    sig = evt.formality_signals
    if not sig:
        return BidClassification(
            label="Uncertain",
            rule_applied=None,
            basis="No formality_signals; residual case.",

