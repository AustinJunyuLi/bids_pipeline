def _quote_first_actor_payload(actors: list[dict], blocks: list[dict]) -> dict:
    actor_quotes: list[dict] = []
    actor_records: list[dict] = []
    default_block_id = blocks[0]["block_id"]
    for actor in actors:
        quote_id = f"quote_actor_{actor['actor_id']}"
        actor_quotes.append(
