                "advised_actor_id": None,
                "bidder_kind": actor.get("bidder_kind"),
                "listing_status": "private",
                "geography": "domestic",
                "is_grouped": False,
                "group_size": None,
                "group_label": None,
                "quote_ids": [quote_id],
                "notes": [],
            }
        )
    return {
        "quotes": actor_quotes,
        "actors": actor_records,
        "count_assertions": [],
        "unresolved_mentions": [],
    }


