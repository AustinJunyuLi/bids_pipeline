from datetime import datetime, timedelta, date

def normalize_actor(name):
    if name is None or str(name) == "NA":
        return None
    n = str(name).lower().strip()
    for suffix in [" inc", " corp", " co", " llc", " ltd"]:
        if n.endswith(suffix):
            n = n[:-len(suffix)].strip()
    if n.startswith("the "):
        n = n[4:]
    n = " ".join(n.split())
    return n

def parse_date(d):
    if d is None or str(d) == "NA" or str(d) == "None":
        return None
    s = str(d).strip()
    for fmt in ["%Y-%m-%dT%H:%M:%S", "%Y-%m-%d %H:%M:%S", "%Y-%m-%d"]:
        try:
            return datetime.strptime(s, fmt).date()
        except ValueError:
            continue
    return None

def is_na(v):
    return v is None or str(v).strip() in ("NA", "None", "")

def ds(d):
    return str(d) if d else None

def classify_alex(row):
    note = str(row.get("bid_note", "NA")).strip()
    bid_val = row.get("bid_value", "NA")
    bid_lower = row.get("bid_value_lower", "NA")
    if note == "IB": return "ib_retention"
    if note == "Bidder Interest": return "bidder_interest"
    if note == "NDA": return "nda"
    if note in ("Drop","DropM","DropTarget","DropBelowInf","DropAtInf","DropBelowM"): return "drop"
    if note == "Target Sale": return "target_sale"
    if note == "Executed": return "executed"
    if note == "Bid Press Release": return "bid_press_release"
    if note == "Final Round Ann": return "final_round_ann"
    if note == "Final Round": return "final_round"
    if note in ("NA", None, ""):
        if (not is_na(bid_val)) or (not is_na(bid_lower)):
            return "proposal"
    return "unknown"

def derive_alex_type(row):
    mixed = row.get("bidder_type_mixed", "NA")
    strat = row.get("bidder_type_strategic", "NA")
    fin = row.get("bidder_type_financial", "NA")
    non_us = row.get("bidder_type_nonUS", "NA")
    if mixed not in ("NA", None, 0, "0") and mixed: return "S/F"
    if strat not in ("NA", None, 0, "0") and strat:
        if non_us not in ("NA", None, 0, "0") and non_us:
            return "non-US public S"
        return "S"
    if fin not in ("NA", None, 0, "0") and fin: return "F"
    return None

def actor_set_match(pipeline_bidders_norm, alex_bidder_norm):
    if alex_bidder_norm is None:
        return len(pipeline_bidders_norm) == 0 or all(b is None for b in pipeline_bidders_norm)
    pipeline_set = set(b for b in pipeline_bidders_norm if b is not None)
    alex_fixed = alex_bidder_norm.replace("spnosor", "sponsor")
    if pipeline_set == {alex_fixed}:
        return True
    if "/" in alex_fixed:
        parts = alex_fixed.split("/")
        if len(parts) == 2:
            base = parts[0].strip()
            suffix = parts[1].strip()
            base_words = base.split()
            if len(base_words) > 1 and " " not in suffix:
                prefix = " ".join(base_words[:-1])
                expanded = {base, prefix + " " + suffix}
                if pipeline_set == expanded:
                    return True
    return False

def dates_within(d1, d2, days=3):
    if d1 is None or d2 is None:
        return False
    return abs((d1 - d2).days) <= days

