def get_span_context(span_id, context_lines=5):
    if span_id not in spans:
        return None
    sp = spans[span_id]
    sl = sp.get("start_line", 0)
    el = sp.get("end_line", sl)
    start = max(1, sl - context_lines)
    end = el + context_lines
    lines = []
    for ln in range(start, end+1):
        if ln in filing_lines:
            lines.append(filing_lines[ln])
    return "\n".join(lines)

