        pipe_note = csv_row.get("note", "NA")
        alex_note = str(a["bid_note"])
        if pipe_note != alex_note and not (is_na(pipe_note) and is_na(alex_note)):
            mismatches_for_pair.append({
                "field": "dropout_subtype",
                "pipeline_value": pipe_note,
                "alex_value": alex_note,
            })

    # --- Arbitrate each mismatch ---
    for mm in mismatches_for_pair:
        filing_context = None
        for sid in p["evidence_span_ids"]:
            ctx = get_span_context(sid, 5)
            if ctx:
                filing_context = ctx
                break

        field = mm["field"]
        pv = mm["pipeline_value"]
        av = mm["alex_value"]

        if field == "date_rough":
            pd_val = parse_date(pv)
            ad_val = parse_date(av)
            if pd_val and ad_val and pd_val.year == ad_val.year and pd_val.month == ad_val.month:
                mm["filing_supports"] = "both"
                mm["arbitration_note"] = "Same month; date coding convention difference"
            elif filing_context:
                if pv and pv in filing_context:
                    mm["filing_supports"] = "pipeline"
                elif av and av in filing_context:
                    mm["filing_supports"] = "alex"
                else:
                    mm["filing_supports"] = "inconclusive"
            else:
                mm["filing_supports"] = "inconclusive"

        elif field == "date_precise":
            if filing_context:
                # Search for specific date mentions
                pv_found = pv and any(pv.replace("-", "") in filing_context.replace(" ", "") or pv in filing_context for _ in [1])
                av_found = av and any(av.replace("-", "") in filing_context.replace(" ", "") or av in filing_context for _ in [1])
                if pv_found and not av_found:
                    mm["filing_supports"] = "pipeline"
                elif av_found and not pv_found:
                    mm["filing_supports"] = "alex"
                elif pv_found and av_found:
                    mm["filing_supports"] = "both"
                else:
                    mm["filing_supports"] = "inconclusive"
            else:
                mm["filing_supports"] = "no_evidence"

        elif field == "bid_value":
            if filing_context:
                pv_in = pv and ("$" + str(pv) in filing_context or str(pv) in filing_context)
                av_in = av and ("$" + str(av) in filing_context or str(av) in filing_context)
                if pv_in and not av_in:
                    mm["filing_supports"] = "pipeline"
                elif av_in and not pv_in:
                    mm["filing_supports"] = "alex"
                elif pv_in and av_in:
                    mm["filing_supports"] = "both"
                else:
                    mm["filing_supports"] = "inconclusive"
            else:
                mm["filing_supports"] = "no_evidence"

        elif field == "bid_type":
            mm["filing_supports"] = "inconclusive"
            mm["arbitration_note"] = "Bid type classification is interpretive"

        elif field == "bidder_type":
            mm["filing_supports"] = "inconclusive"
            mm["arbitration_note"] = "Bidder type derivation methodology differs"

        elif field == "all_cash":
            if filing_context and "cash" in filing_context.lower():
                mm["filing_supports"] = "both"
            else:
                mm["filing_supports"] = "inconclusive"

        elif field == "dropout_subtype":
            mm["filing_supports"] = "inconclusive"
            mm["arbitration_note"] = "Dropout subtype is interpretive"

        else:
            mm["filing_supports"] = "inconclusive"

    if mismatches_for_pair:
        field_mismatches.append({
            "pipeline_event_id": eid,
            "alex_bidder_id": a["bidder_id"],
            "match_detail": detail,
            "mismatches": mismatches_for_pair
        })

